# Operator-local secrets. Copy to .env (gitignored) and fill in real values.
#
#     cp .env.example .env
#     chmod 600 .env
#
# Loaded automatically by the justfile (set dotenv-load := true).

# Required for mechanism β real-LLM e2e tests (AC #1, #3, #7, #8).
# Advances H_T-AS-8d + H_T-OD-5 from RETIRE-READY → RETIRED.
ANTHROPIC_API_KEY=

# Optional: other provider keys, when their tests come online.
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Optional R-830 live S3 memory backend e2e. `R830_S3_BUCKET` is required.
# Preferred auth path: `aws login --profile r830 --region us-east-2`, then set
# `R830_S3_PROFILE=r830`. Static AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY remain
# supported as a fallback through boto3's normal provider chain.
# R830_S3_BUCKET=
# R830_S3_KEY_PREFIX=r830-live-e2e
# R830_S3_REGION=
# R830_S3_PROFILE=
# R830_S3_ENDPOINT_URL=

# Optional R-830 live managed-DB memory backend e2e. Use a disposable or
# provisioned PostgreSQL-compatible managed database.
# R830_MANAGED_DB_CONNECTION_STRING=
